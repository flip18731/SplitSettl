# ─── Smart contracts (Hardhat) ─────────────────────────────────
PRIVATE_KEY=your_private_key_here

# Used by seed script after deploy (same as SplitSettl address)
CONTRACT_ADDRESS=0x_deployed_contract_address

# ─── Next.js frontend (.env.local in frontend/ or root for Vercel) ───
NEXT_PUBLIC_CHAIN_ID=133
# 133 = HashKey Chain Testnet, 177 = Mainnet

# Optional — wallet RPC (defaults in code if unset)
NEXT_PUBLIC_RPC_URL=https://testnet.hsk.xyz

NEXT_PUBLIC_CONTRACT_ADDRESS=0x_deployed_splitsettl_address
NEXT_PUBLIC_MOCK_USDT_ADDRESS=0x_deployed_mock_usdt_address

# At least one LLM key recommended (analyze route)
ANTHROPIC_API_KEY=sk-ant-your_api_key_here
# Optional: OPENAI_API_KEY=sk-...
# Optional: AI_ANALYSIS_PROVIDER=auto|openai|anthropic
GITHUB_TOKEN=ghp_your_github_token_here

# Optional: notify an internal endpoint when testing HSP message flows (server-side only)
# HSP_NOTIFY_URL=

# ─── HashKey Merchant API (HSP / HP2) — request app_key + app_secret: hsp_hackathon@hashkey.com ───
# HSP_API_BASE=https://merchant-qa.hashkeymerchant.com
# HSP_APP_KEY=ak_xxxxxxxx
# HSP_APP_SECRET=
# HSP_MERCHANT_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"
# Optional overrides:
# HSP_PAY_TO_ADDRESS=0x...          # defaults to NEXT_PUBLIC_CONTRACT_ADDRESS
# HSP_MERCHANT_NAME=SplitSettl
# HSP_SETTLEMENT_COIN=USDT          # or USDC (testnet)
# NEXT_PUBLIC_APP_URL=http://localhost:3000   # redirect after HSP checkout

# Official testnet token overrides (defaults match HSP docs if unset):
# NEXT_PUBLIC_HSP_USDT_ADDRESS=0x372325443233fEbaC1F6998aC750276468c83CC6
# NEXT_PUBLIC_HSP_USDC_ADDRESS=0x79AEc4EeA31D50792F61D1Ca0733C18c89524C9e
