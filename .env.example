# ─── Smart contracts (Hardhat) ─────────────────────────────────
PRIVATE_KEY=your_private_key_here

# Used by seed script after deploy (same as SplitSettl address)
CONTRACT_ADDRESS=0x_deployed_contract_address

# ─── Next.js frontend (.env.local in frontend/ or root for Vercel) ───
NEXT_PUBLIC_CHAIN_ID=133
# 133 = HashKey Chain Testnet, 177 = Mainnet

# Optional — wallet RPC (defaults in code if unset)
NEXT_PUBLIC_RPC_URL=https://testnet.hsk.xyz

NEXT_PUBLIC_CONTRACT_ADDRESS=0x_deployed_splitsettl_address
NEXT_PUBLIC_MOCK_USDT_ADDRESS=0x_deployed_mock_usdt_address

# AI analysis (OpenAI only — /api/ai/analyze)
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
# AI_ANALYSIS_PROVIDER=auto   # auto|openai — both use OpenAI when OPENAI_API_KEY is set
GITHUB_TOKEN=ghp_your_github_token_here

# Optional: notify an internal endpoint when testing HSP message flows (server-side only)
# HSP_NOTIFY_URL=

# ─── HashKey Merchant API (HSP / HP2) — request app_key + app_secret: hsp_hackathon@hashkey.com ───
# HSP_API_BASE=https://merchant-qa.hashkeymerchant.com
# HSP_APP_KEY=ak_xxxxxxxx
# HSP_APP_SECRET=
# HSP_MERCHANT_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"
# Optional overrides:
# HSP_PAY_TO_ADDRESS=0x...          # defaults to NEXT_PUBLIC_CONTRACT_ADDRESS
# HSP_MERCHANT_NAME=SplitSettl
# HSP_SETTLEMENT_COIN=USDC         # or USDT — must match tokens enabled in Merchant dashboard
# Full redirect URL after checkout (HTTPS). If unset, uses https NEXT_PUBLIC_APP_URL or split-settl.vercel.app
# HSP_REDIRECT_URL=https://split-settl.vercel.app/invoice?hsp=complete
# NEXT_PUBLIC_APP_URL=http://localhost:3000   # local dev; HSP redirect still uses HTTPS fallback if not https
# x402 v2 defaults: CAIP-2 network `eip155:133` (testnet) / `eip155:177` (mainnet) — see https://docs.x402.org/
# Override or legacy HashKey strings:
# HSP_X402_NETWORK_TESTNET=hashkey-testnet
# HSP_X402_USE_LEGACY_NETWORK=1    # use hashkey-testnet / hashkey instead of eip155:*
# HSP_CHAIN_ID_JSON_TYPE=string    # JSON-string chain_id ("133") if gateway rejects number
# HSP_MINIMAL_CART=1               # smoke: single $1.00 line, no invoice body required
# HSP_DEBUG=1                      # log canonical cart prefix in server logs

# Official testnet token overrides (defaults match HSP docs if unset):
# NEXT_PUBLIC_HSP_USDT_ADDRESS=0x372325443233fEbaC1F6998aC750276468c83CC6
# NEXT_PUBLIC_HSP_USDC_ADDRESS=0x8FE3cB719Ee4410E236Cd6b72ab1fCDC06eF53c6
#
# Server-side x402 `contract_address` overrides (create-order / HSP client only):
# HSP_USDC_ADDRESS_TESTNET=0x8FE3cB719Ee4410E236Cd6b72ab1fCDC06eF53c6
# HSP_USDT_ADDRESS_TESTNET=0x372325443233fEbaC1F6998aC750276468c83CC6
# If QA only whitelists legacy USDC: HSP_USDC_ADDRESS_TESTNET=0x79AEc4EeA31D50792F61D1Ca0733C18c89524C9e
